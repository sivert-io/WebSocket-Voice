# port clients connect to
PORT=5000

# your secure SFU host
SFU_WS_HOST="wss://sfu_host.com"

# comma separated list of URLs
STUN_SERVERS="stun:stun.l.google.com:19302"

# Name of the server
SERVER_NAME="My Brand New Server"

# Icon of the server (filename in the public folder)
SERVER_ICON="example.png"

# Websocket allowed origins
# CORS_ORIGIN="*" # if you want to allow any clients to connect
CORS_ORIGIN="https://gryt.chat" # if you only want the official client to connect

# Websocket secret token (also used for SFU authentication)
SERVER_TOKEN="123"

# SFU Server ID (unique identifier for this server, automatically generated from SERVER_NAME if not set)
# SFU_SERVER_ID="my_custom_server_id"

# ScyllaDB / Cassandra settings
SCYLLA_CONTACT_POINTS=192.168.10.168
SCYLLA_LOCAL_DATACENTER=datacenter1
SCYLLA_KEYSPACE=gryt
SCYLLA_USERNAME=root
SCYLLA_PASSWORD=Saiverx123

# S3 / Object storage (AWS S3, Cloudflare R2, Wasabi, MinIO)
S3_REGION=auto
S3_ENDPOINT=http://192.168.10.168:9768
S3_ACCESS_KEY_ID=root
S3_SECRET_ACCESS_KEY=Saiverx
S3_BUCKET=gryt-bucket
S3_FORCE_PATH_STYLE=true